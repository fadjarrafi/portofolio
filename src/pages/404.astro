---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Not Found" noindex>
  <section class="flex flex-col items-start justify-center min-h-[60vh]">
    <h1 class="font-semibold text-2xl tracking-tighter mb-4">404 – Page Not Found</h1>
    <p class="text-neutral-600 dark:text-neutral-400 mb-6">
      The page you're looking for doesn't exist.
    </p>
    <a href="/" class="text-sm underline hover:no-underline">Go home</a>
  </section>
</BaseLayout>
