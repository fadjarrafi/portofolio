---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { formatDate } from '../../utils/format';
import { calculateReadingTime } from '../../utils/posts';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const readingTime = calculateReadingTime(entry.body ?? '');

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://fadjarrafi.com';
const ogImage = entry.data.image ?? `${siteUrl}/og-default.png`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  datePublished: entry.data.publishedAt,
  description: entry.data.summary,
  image: ogImage,
  url: `${siteUrl}/case-studies/${entry.id}`,
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  ogImage={ogImage}
  publishedAt={entry.data.publishedAt}
  type="article"
>
  <Nav />

  <section class="max-w-4xl mx-auto px-6 pb-16">
    <script type="application/ld+json" set:html={jsonLd} />

    <div class="scroll-animate">
      <a
        href="/case-studies"
        class="inline-flex items-center text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 mb-8 py-2 px-2 -ml-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
          <path d="m15 18-6-6 6-6" />
        </svg>
        Back
      </a>

      {entry.data.image && (
        <div class="relative aspect-video mb-8 rounded-lg overflow-hidden bg-neutral-100 dark:bg-neutral-900">
          <img src={entry.data.image} alt={entry.data.title} class="object-cover w-full h-full" />
        </div>
      )}

      <div class="mb-8">
        <h1 class="font-semibold text-2xl tracking-tighter mb-3">{entry.data.title}</h1>
        <p class="text-neutral-600 dark:text-neutral-400 mb-4">{entry.data.summary}</p>

        <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-600 dark:text-neutral-400">
          <time datetime={entry.data.publishedAt}>{formatDate(entry.data.publishedAt)}</time>
          {entry.data.client && <><span>·</span><span>Client: {entry.data.client}</span></>}
          {entry.data.role && <><span>·</span><span>Role: {entry.data.role}</span></>}
          {entry.data.duration && <><span>·</span><span>{entry.data.duration}</span></>}
          <span>·</span>
          <span>{readingTime} min read</span>
        </div>

        {entry.data.topics && entry.data.topics.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {entry.data.topics.map((topic) => (
              <span class="px-3 py-1 text-xs bg-neutral-100 dark:bg-neutral-800 rounded-full text-neutral-700 dark:text-neutral-300">
                {topic}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>

    <div class="scroll-animate" data-delay="100">
      <article class="prose prose-neutral dark:prose-invert prose-p:my-6 w-full leading-8">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>
