---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import GardenNav from '../../../components/GardenNav.astro';
import ConceptsSearch from '../../../components/ConceptsSearch.astro';

let concepts: any[] = [];
try {
  const data = readFileSync(resolve('public/data/concepts.json'), 'utf-8');
  concepts = JSON.parse(data);
} catch {}

const allDomains = [...new Set(concepts.flatMap((c: any) => c.domain ?? []))].sort();
---

<BaseLayout title="Concepts" description="Personal lexicon — terms I've defined for myself.">
  <Nav />
  <section class="min-h-screen pb-16">
    <div class="max-w-5xl mx-auto">
      <div class="scroll-animate">
        <h1 class="font-semibold text-2xl mb-1 tracking-tighter">Concepts</h1>
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-8">Personal lexicon — terms I've defined for myself.</p>
      </div>
      <div class="scroll-animate" data-delay="50">
        <GardenNav />
      </div>
      {concepts.length === 0 ? (
        <div class="scroll-animate" data-delay="100">
          <p class="text-sm text-neutral-500">No concepts yet.</p>
        </div>
      ) : (
        <div class="scroll-animate" data-delay="100">
          <ConceptsSearch concepts={concepts} allDomains={allDomains} />
        </div>
      )}
    </div>
  </section>
</BaseLayout>
