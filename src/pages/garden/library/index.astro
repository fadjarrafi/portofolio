---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import GardenNav from '../../../components/GardenNav.astro';

let library: any[] = [];
try {
  const data = readFileSync(resolve('public/data/library.json'), 'utf-8');
  library = JSON.parse(data);
} catch {}
---

<BaseLayout title="Library" description="Reading notes and resources.">
  <Nav />
  <section class="min-h-screen pb-16">
    <div class="max-w-5xl mx-auto">
      <div class="scroll-animate">
        <h1 class="font-semibold text-2xl mb-1 tracking-tighter">Library</h1>
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-8">Reading notes and resources.</p>
      </div>
      <div class="scroll-animate" data-delay="50">
        <GardenNav />
      </div>
      {library.length === 0 ? (
        <div class="scroll-animate" data-delay="100">
          <p class="text-sm text-neutral-500">No library entries yet.</p>
        </div>
      ) : (
        <div class="grid gap-4 scroll-animate" data-delay="100">
          {library.map((item: any) => (
            <div class="border border-neutral-200 dark:border-neutral-800 rounded-lg p-5">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                <div>
                  {item.url ? (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-semibold text-lg tracking-tight hover:underline underline-offset-2"
                    >
                      {item.title}
                    </a>
                  ) : (
                    <h2 class="font-semibold text-lg tracking-tight">{item.title}</h2>
                  )}
                  <p class="text-sm text-neutral-500 dark:text-neutral-500">{item.author} · {item.year}</p>
                </div>
                <div class="flex flex-col items-end gap-1">
                  <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${
                    item.status === 'completed'
                      ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400'
                      : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400'
                  }`}>
                    {item.status === 'completed' ? 'Completed' : 'Reading'}
                  </span>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
                    {item.type}
                  </span>
                </div>
              </div>
              {item.rating && (
                <div class="flex gap-0.5 mb-2">
                  {Array.from({ length: 5 }, (_, i) => (
                    <span class={i < item.rating ? 'text-yellow-400' : 'text-neutral-300 dark:text-neutral-700'}>★</span>
                  ))}
                </div>
              )}
              {item.summary && (
                <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">{item.summary}</p>
              )}
              {item.keyTakeaways?.length > 0 && (
                <div class="mb-2">
                  <p class="text-xs font-medium text-neutral-500 uppercase tracking-wider mb-1">Key Takeaways</p>
                  <ul class="list-disc list-inside space-y-0.5">
                    {item.keyTakeaways.map((t: string) => (
                      <li class="text-sm text-neutral-600 dark:text-neutral-400">{t}</li>
                    ))}
                  </ul>
                </div>
              )}
              {item.topics?.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-2">
                  {item.topics.map((t: string) => (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
                      {t}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
