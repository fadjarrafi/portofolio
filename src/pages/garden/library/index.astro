---
import { readFileSync } from 'fs';
import { resolve } from 'path';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import GardenNav from '../../../components/GardenNav.astro';

let library: any[] = [];
try {
  const data = readFileSync(resolve('public/data/library.json'), 'utf-8');
  library = JSON.parse(data);
} catch {}
---

<BaseLayout title="Library" description="Reading notes and resources.">
  <Nav />
  <section class="min-h-screen pb-16">
    <div class="max-w-5xl mx-auto">
      <div class="scroll-animate">
        <h1 class="font-semibold text-2xl mb-1 tracking-tighter">Library</h1>
        <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-8">Reading notes and resources.</p>
      </div>
      <div class="scroll-animate" data-delay="50">
        <GardenNav />
      </div>
      {library.length === 0 && (
        <div class="scroll-animate" data-delay="100">
          <p class="text-sm text-neutral-500">No library entries yet.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
