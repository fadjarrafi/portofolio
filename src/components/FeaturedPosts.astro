---
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/format';

const allPosts = await getCollection('blog', ({ id, data }) => {
  return id.startsWith('en/') && data.featured === true;
});

const featuredPosts = allPosts.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
---

<div>
  <div class="scroll-animate" data-delay="0">
    <h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400 mb-6">Writing</h2>
  </div>
  <div class="space-y-6">
    {featuredPosts.map((post) => {
      const slug = post.id.replace('en/', '').replace(/\.mdx?$/, '');
      return (
        <div class="scroll-animate" data-delay="100">
          <a class="block group" href={`/writing/en/${slug}`}>
            <p class="text-xs text-neutral-400 dark:text-neutral-500 tabular-nums mb-1">
              {formatDate(post.data.publishedAt, false)}
            </p>
            <p class="text-base font-medium mb-1 group-hover:underline">{post.data.title}</p>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">{post.data.summary}</p>
          </a>
        </div>
      );
    })}
  </div>
</div>
