---
import { getCollection } from 'astro:content';

const allStudies = await getCollection('case-studies', ({ data }) => data.featured === true);
const studies = allStudies
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

if (studies.length === 0) return;
---

<div>
  <div class="flex items-center justify-between mb-6">
    <h2 class="font-semibold text-lg tracking-tighter">Case Studies</h2>
    <a
      href="/case-studies"
      class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
    >
      View all
    </a>
  </div>
  <div class="grid gap-4">
    {studies.map((study) => (
      <a href={`/case-studies/${study.id.replace(/\.mdx?$/, '')}`} class="group block">
        <article class="p-4 border border-neutral-200 dark:border-neutral-800 rounded-lg hover:border-neutral-400 dark:hover:border-neutral-600 transition-colors">
          <div class="min-w-0">
            <h3 class="font-medium text-neutral-900 dark:text-neutral-100 mb-1 group-hover:text-neutral-600 dark:group-hover:text-neutral-400 transition-colors truncate">
              {study.data.title}
            </h3>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2">{study.data.summary}</p>
            {study.data.topics && study.data.topics.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-2">
                {study.data.topics.slice(0, 3).map((topic) => (
                  <span class="px-2 py-0.5 text-xs bg-neutral-100 dark:bg-neutral-800 rounded text-neutral-600 dark:text-neutral-400">
                    {topic}
                  </span>
                ))}
              </div>
            )}
          </div>
        </article>
      </a>
    ))}
  </div>
</div>
